# =============================================================================
# CivicLink — environment template (Segment 1.4)
# Copy to web/.env.local — never commit .env.local or real secrets.
# Summaries below are for onboarding only; verify auth, fields, and quotas in
# each vendor’s current docs and in Federal Legislation _ Federal Government Actions (1).pdf
# =============================================================================

# -----------------------------------------------------------------------------
# Application (Next.js)
# -----------------------------------------------------------------------------
# Public base URL for absolute links, email templates, OAuth callbacks (adjust per env).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment is usually set by the host (development | production | test).

# -----------------------------------------------------------------------------
# 2.1 Federal legislation & government actions
# -----------------------------------------------------------------------------
# Congress.gov API — https://api.congress.gov/
#   Signup: Data.gov / congress.gov signup. Auth: X-Api-Key or api_key query.
#   Returns: bills, amendments, summaries, committees, members, nominations,
#   House/Senate communications, vote data (where exposed), CRS reports, treaties, etc.
CONGRESS_GOV_API_KEY=

# GovInfo API — https://api.govinfo.gov/docs/
#   Signup: govinfo. Auth: api_key query parameter.
#   Returns: BILLS packages, BILLSTATUS XML/JSON, Federal Register, collections,
#   package-level full text (more parsing than Congress.gov for raw text).
GOVINFO_API_KEY=

# LegiScan API — https://legiscan.com/legiscan
#   Returns: unified JSON for bill text, status, sponsors, committees, votes;
#   federal + state via parameters; free tier quotas; CC-BY attribution (verify terms).
LEGISCAN_API_KEY=

# ProPublica Congress API (legacy) / bulk data — often bulk downloads vs single key.
#   Returns: historical or bulk federal datasets (check current ProPublica offering).
PROPUBLICA_API_KEY=

# BillTrack50 (paid, Phase 2) — subscription product with API per research PDF.
#   Returns: commercial legislative tracking; confirm fields with vendor.
BILLTRACK50_API_KEY=

# -----------------------------------------------------------------------------
# 2.2 State legislation
# -----------------------------------------------------------------------------
# Open States v3 — https://docs.openstates.org/api-v3/
#   Auth: X-API-KEY or apikey query.
#   Returns: jurisdictions, bills, people, committees, events, geo queries for legislators.
OPENSTATES_API_KEY=

# Quorum (paid) — optional scale tier; vendor-specific auth.
#   Returns: state/federal datasets per subscription.
QUORUM_API_KEY=

# -----------------------------------------------------------------------------
# 2.3 Local government (pilot: one city / Granicus Legistar pattern)
# -----------------------------------------------------------------------------
# Many Legistar / Granicus deployments use a per-customer API token.
# Replace with your pilot city’s docs; store additional jurisdictions in DB later.
LEGISTAR_API_KEY=
LEGISTAR_BASE_URL=

# Council Data Project / custom open data — placeholder if you use a city Open Data token.
CITY_OPEN_DATA_APP_TOKEN=

# Apify or similar (optional) — Municode / scraper workloads; treat as unofficial.
APIFY_API_TOKEN=

# -----------------------------------------------------------------------------
# 2.4 Civic & political events
# -----------------------------------------------------------------------------
# Eventbrite — https://www.eventbrite.com/platform/api/
#   Auth: Bearer private token.
#   Returns: events, venues, organizations; filter by geo and keywords for civic relevance.
EVENTBRITE_PRIVATE_TOKEN=

# Meetup GraphQL API — OAuth — https://www.meetup.com/api/guide/
#   Register an OAuth app; redirect URI must match your NEXT_PUBLIC_APP_URL path.
MEETUP_OAUTH_CLIENT_ID=
MEETUP_OAUTH_CLIENT_SECRET=

# VolunteerMatch — https://developers.volunteermatch.org/api-docs
#   Returns: volunteer opportunities; align with GraphQL or REST per current docs.
VOLUNTEER_MATCH_API_KEY=

# All For Good / volunteer aggregators (verify current API name and access).
#   Returns: additional volunteer / civic listings for merge/dedupe pipelines.
ALL_FOR_GOOD_API_KEY=

# -----------------------------------------------------------------------------
# 2.5 Voting information
# -----------------------------------------------------------------------------
# Google Civic Information — https://developers.google.com/civic-information/docs/using_api
#   Auth: key query param (Google Cloud API key with Civic API enabled).
#   Returns: voterInfoQuery, representativeInfoByAddress, elections (coverage varies).
GOOGLE_CIVIC_API_KEY=

# Vote Smart — https://votesmart.org/votesmart-api
#   Returns: officials, candidates, bills, votes, ratings, election tools / deadlines.
VOTESMART_API_KEY=

# Democracy Works / Open 5070 / TurboVote-class APIs (Phase 2; vendor-specific).
#   Returns: comprehensive election data where contracted; confirm with provider.
DEMOCRACY_WORKS_API_KEY=
OPEN5070_API_KEY=

# -----------------------------------------------------------------------------
# 2.6 ZIP / geolocation / districts
# -----------------------------------------------------------------------------
# GeoNames — https://www.geonames.org/export/web-services.html
#   Returns: postal code / placename lookup, lat/lng (free tier with registered username).
GEONAMES_USERNAME=

# US Census Geocoding — https://geocoding.census.gov/ — typically no API key for public tier.
#   Returns: matched addresses, census geographies, state leg + congressional districts.
#   Set a custom User-Agent string for server-side requests if required by your HTTP client.
CENSUS_GEOCODER_BASE_URL=https://geocoding.census.gov/geocoder

# Optional: Google Maps Geocoding (paid / quota) for harder addresses.
GOOGLE_MAPS_GEOCODING_API_KEY=

# Nominatim (OpenStreetMap) — public; send a descriptive User-Agent per usage policy.
NOMINATIM_USER_AGENT=CivicLink/0.1 (contact: you@example.com)

# FCC Census Block API — optional cross-check — https://geo.fcc.gov/api/census/
#   Returns: block FIPS from lat/lng (often no key).
FCC_CENSUS_BLOCK_BASE_URL=https://geo.fcc.gov/api/census

# Map tiles / Mapbox (optional UI) — public token only if used client-side; prefer server proxy for secrets.
NEXT_PUBLIC_MAPBOX_TOKEN=

# -----------------------------------------------------------------------------
# 2.7 Trust / optional claim context
# -----------------------------------------------------------------------------
# Google Fact Check Tools — https://developers.google.com/fact-check/tools/api/reference/rest
#   Returns: ClaimReview / fact-check articles linked to URLs or queries.
GOOGLE_FACTCHECK_API_KEY=

# Media Cloud, GDELT, NewsAPI, etc. (Phase 2/3) — add when product needs them.
MEDIA_CLOUD_API_KEY=
GDELT_API_KEY=
NEWSAPI_API_KEY=

# -----------------------------------------------------------------------------
# Persistence & cache (Segments 4 and 13)
# -----------------------------------------------------------------------------
# PostgreSQL — e.g. Neon, Supabase, RDS (server-only; never NEXT_PUBLIC_).
DATABASE_URL=

# Redis / queue (Phase 2 workers, caching) — server-only.
REDIS_URL=

# -----------------------------------------------------------------------------
# Auth (Segment 10 — placeholders)
# -----------------------------------------------------------------------------
# NextAuth (if used) — generate NEXTAUTH_SECRET with openssl rand -base64 32
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=

# OAuth provider keys (examples; add only what you enable)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Observability (Segment 12)
# -----------------------------------------------------------------------------
# Sentry — https://sentry.io — DSN is safe to scope per environment.
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=   # CI upload only; do not ship to browsers

# -----------------------------------------------------------------------------
# AI / NLP (Segment 13 — optional; server-only keys)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
